    "level": {
      "items": {
        "enum": [
          "beginner",
          "intermediate",
          "advanced",
          "pre-professional",
          "professional",
          "open"
        ],
        "type": "string"
      },
      "title": "Level",
      "type": "array"
    },
    "lifecycle": {
      "default": "scheduled",
      "enum": [
        "scheduled",
        "cancelled",
        "postponed"
      ],
      "title": "Lifecycle",
      "type": "string"
