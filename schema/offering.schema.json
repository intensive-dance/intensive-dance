          "default": null,
          "title": "Slug"
        }
      },
      "required": [
        "organization"
      ],
      "title": "Affiliation",
      "type": "object"
    },
    "Application": {
      "properties": {
        "deadline": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deadline"
