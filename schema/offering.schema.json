        "requirements": {
          "items": {
            "discriminator": {
              "mapping": {
                "cv": "#/$defs/CVReq",
                "headshot": "#/$defs/HeadshotReq",
                "none": "#/$defs/NoneReq",
                "photos": "#/$defs/PhotosReq",
                "video": "#/$defs/VideoReq"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/NoneReq"
              },
              {
                "$ref": "#/$defs/PhotosReq"
              },
              {
                "$ref": "#/$defs/VideoReq"
              },
              {
                "$ref": "#/$defs/CVReq"
              },
              {
                "$ref": "#/$defs/HeadshotReq"
              }
            ]
          },
          "title": "Requirements",
          "type": "array"
